<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        DEBUG-only policy — overrides the release config in debuggable builds (src/debug wins over src/main).
        Never included in release APKs.

        base-config: allow cleartext to any host in debug. This is intentional:
          - Tailscale raw IPs (100.x.x.x) cannot be matched by <domain> elements (CIDR not supported).
          - Traffic over Tailscale is always WireGuard-encrypted at the network level regardless.
          - This config is never shipped in release APKs.

        domain-config entries are kept for documentation (emulator alias, MagicDNS domain).
    -->
    <base-config cleartextTrafficPermitted="true" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="true">ts.net</domain>
    </domain-config>
</network-security-config>
